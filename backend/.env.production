# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://prodigitalix.com

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Remplacer [PASSWORD] et [PROJECT_REF] par vos valeurs Supabase
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true
# Connexion directe (pour les migrations)
DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGEZ_MOI_MINIMUM_64_CARACTERES_ALEATOIRES_SECURISES
JWT_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Facebook OAuth ────────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@yourproject.iam.gserviceaccount.com

# ── Chariow Webhook ───────────────────────────────────────────────────────────
CHARIOW_WEBHOOK_SECRET=votre_secret_webhook_chariow

# ── Chiffrement clés API ──────────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGEZ_MOI_32_CARACTERES_EXACTEMENT

# ── Sauvegardes ───────────────────────────────────────────────────────────────
BACKUP_DIR=/opt/backups/prodigitalix

# ── Monitoring (Slack/Discord webhook) ───────────────────────────────────────
MONITORING_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Email (SendGrid / Resend / SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG....
FROM_EMAIL=noreply@prodigitalix.com
FROM_NAME=PRO DIGITALIX
